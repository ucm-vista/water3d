# PocketBase is scaffolded but disabled by default.
# Set VITE_POCKETBASE_ENABLED=true only when backend collections and auth flow are ready.
VITE_POCKETBASE_ENABLED=false
VITE_POCKETBASE_URL=
VITE_POCKETBASE_FIELDS_COLLECTION=fields
VITE_POCKETBASE_OPENET_CACHE_COLLECTION=openet_cache

# Mapbox powers the setup-only field location picker.
VITE_MAPBOX_ACCESS_TOKEN=
VITE_MAPBOX_STYLE_URL=

# OpenET provides historical ET, reference ET, precipitation, NDVI, and quality metadata.
# Keep this disabled until requests are routed through a backend/proxy for production.
VITE_OPENET_ENABLED=false
VITE_OPENET_BASE_URL=https://openet-api.org
VITE_OPENET_PROXY_BASE_URL=/api/openet
VITE_OPENET_ACCESS_TOKEN=
VITE_OPENET_DEFAULT_MODEL=Ensemble
VITE_OPENET_REFERENCE_ET=gridMET
VITE_OPENET_UNITS=mm
VITE_OPENET_VERSION=2.1
# Optional: set only if OpenET availability lags and requests need to be capped.
VITE_OPENET_MAX_AVAILABLE_DATE=

# NRCS Soil Data Access provides SSURGO map unit/component soil properties by coordinate.
VITE_SOIL_DATA_ACCESS_ENABLED=false
VITE_SOIL_DATA_ACCESS_BASE_URL=https://sdmdataaccess.nrcs.usda.gov
VITE_SOIL_DATA_ACCESS_PROXY_BASE_URL=/api/soil-data-access

# Climate Toolbox provides 28-day PET forecasts from CFS.
VITE_CLIMATE_TOOLBOX_ENABLED=false
VITE_CLIMATE_TOOLBOX_CFS_BASE_URL=https://climate-dev.nkn.uidaho.edu
VITE_CLIMATE_TOOLBOX_CFS_PROXY_BASE_URL=/api/climate-toolbox

# Open-Meteo provides public historical weather for GDD, VPD, chill, and precipitation.
VITE_OPEN_METEO_ENABLED=true
VITE_OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com
VITE_OPEN_METEO_ARCHIVE_PROXY_BASE_URL=/api/open-meteo

# Optional browser-console diagnostics for API/data-source loading.
VITE_DEBUG_DATA_SOURCES=false
