# Climate Toolbox provides 28-day PET forecasts from CFS.
VITE_CLIMATE_TOOLBOX_ENABLED=false
VITE_CLIMATE_TOOLBOX_CFS_BASE_URL=https://climate-dev.nkn.uidaho.edu
VITE_CLIMATE_TOOLBOX_CFS_PROXY_BASE_URL=/api/climate-toolbox

# gridMET (Climate Toolbox netCDF service) provides observed daily weather and
# reference ET back to 1979, with a ~2-day lag behind today.
VITE_GRIDMET_ENABLED=true
VITE_GRIDMET_BASE_URL=https://toolbox-webservices.nkn.uidaho.edu
VITE_GRIDMET_PROXY_BASE_URL=/api/gridmet

# Open-Meteo provides public historical weather for GDD, VPD, chill, and precipitation.
# Retained only for the chill-hours fetch (sole source of real hourly temps).
VITE_OPEN_METEO_ENABLED=true
VITE_OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com
VITE_OPEN_METEO_ARCHIVE_PROXY_BASE_URL=/api/open-meteo

# Optional browser-console diagnostics for API/data-source loading.
VITE_DEBUG_DATA_SOURCES=false
