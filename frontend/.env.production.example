# Production frontend config. Copy to `.env.production`, then build the web
# image (the values are baked into the bundle).
#
#   cp .env.production.example .env.production
#
# NOTE: every VITE_* value ships in the public client bundle — do not put real
# secrets here. (There are none: the map stack is keyless Esri tiles + OSM
# Nominatim, configured in src/config/map.ts.)

# --- Weather APIs: same-origin /api/* paths that Traefik reverse-proxies in prod ---
# (deploy/traefik/dynamic.yml maps each of these to its upstream; do not point
#  them at the upstream hosts directly or you'll hit CORS.)
VITE_CLIMATE_TOOLBOX_ENABLED=true
VITE_CLIMATE_TOOLBOX_CFS_PROXY_BASE_URL=/api/climate-toolbox

VITE_GRIDMET_ENABLED=true
VITE_GRIDMET_PROXY_BASE_URL=/api/gridmet

VITE_OPEN_METEO_ENABLED=true
VITE_OPEN_METEO_ARCHIVE_PROXY_BASE_URL=/api/open-meteo

VITE_DEBUG_DATA_SOURCES=false
